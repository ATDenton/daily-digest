<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Daily Digest — {{ generated_date }}</title>
<style>
  :root {
    color-scheme: light dark;
    --bg: #f5f6f8;
    --card: #ffffff;
    --text: #1a1d21;
    --muted: #6b7280;
    --border: #e5e7eb;
    --up: #0a7d33;
    --down: #c1121f;
    --accent: #2453ff;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #101214;
      --card: #191c1f;
      --text: #edeef0;
      --muted: #9aa1ab;
      --border: #2b2f34;
      --up: #3ddc7a;
      --down: #ff6b6b;
      --accent: #6f92ff;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.45;
  }
  .wrap { max-width: 720px; margin: 0 auto; padding: 20px 16px 60px; }
  header { margin-bottom: 20px; }
  header h1 { font-size: 1.5rem; margin: 0 0 4px; }
  header .sub { color: var(--muted); font-size: 0.9rem; }
  h2.section-title {
    font-size: 1.05rem;
    margin: 28px 0 10px;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--border);
  }
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    margin-bottom: 12px;
  }
  .quote-grid {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 6px 10px;
    font-size: 0.92rem;
  }
  .quote-grid .name { color: var(--text); }
  .quote-grid .price { color: var(--muted); text-align: right; font-variant-numeric: tabular-nums; }
  .change { text-align: right; font-weight: 600; font-variant-numeric: tabular-nums; min-width: 62px; }
  .change.up { color: var(--up); }
  .change.down { color: var(--down); }
  .commentary { font-size: 0.95rem; margin: 0 0 14px; }
  .headline-list { list-style: none; margin: 0; padding: 0; }
  .headline-list li {
    padding: 8px 0;
    border-top: 1px solid var(--border);
  }
  .headline-list li:first-child { border-top: none; }
  .headline-list a {
    color: var(--text);
    text-decoration: none;
    font-size: 0.94rem;
  }
  .headline-list a:hover { color: var(--accent); }
  .headline-list .meta {
    display: block;
    color: var(--muted);
    font-size: 0.78rem;
    margin-top: 2px;
  }
  footer { margin-top: 30px; color: var(--muted); font-size: 0.8rem; text-align: center; }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1>Daily Digest</h1>
    <div class="sub">{{ generated_date }} · {{ generated_time }}</div>
  </header>

  <h2 class="section-title">Markets</h2>
  <div class="card">
    <p class="commentary">{{ market_commentary }}</p>
  </div>

  {% for region, rows in indices.items() %}
  <div class="card">
    <div class="quote-grid">
      <div class="name" style="color: var(--muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: .04em;">{{ region }}</div>
      <div></div>
      <div></div>
      {% for row in rows %}
      <div class="name">{{ row.name }}</div>
      <div class="price">{{ "%.2f"|format(row.price) }}</div>
      <div class="change {{ 'up' if row.change_pct >= 0 else 'down' }}">{{ "%+.2f"|format(row.change_pct) }}%</div>
      {% endfor %}
    </div>
  </div>
  {% endfor %}

  <div class="card">
    <div class="quote-grid">
      <div class="name" style="color: var(--muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: .04em;">Watchlist</div>
      <div></div>
      <div></div>
      {% for row in watchlist %}
      <div class="name">{{ row.name }}</div>
      <div class="price">{{ "%.2f"|format(row.price) }}</div>
      <div class="change {{ 'up' if row.change_pct >= 0 else 'down' }}">{{ "%+.2f"|format(row.change_pct) }}%</div>
      {% endfor %}
    </div>
  </div>

  {% for section, items in news.items() %}
  <h2 class="section-title">{{ section }}</h2>
  <div class="card">
    <p class="commentary">{{ section_summaries.get(section, "") }}</p>
    <ul class="headline-list">
      {% for item in items %}
      <li>
        <a href="{{ item.link }}" target="_blank" rel="noopener">{{ item.title }}</a>
        <span class="meta">{{ item.source }}</span>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}

  <footer>Generated automatically · sources linked above · not financial advice</footer>
</div>
</body>
</html>
