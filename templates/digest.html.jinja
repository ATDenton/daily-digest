<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Daily Digest — {{ generated_date }}</title>
<style>
  :root {
    color-scheme: light dark;
    --bg: #f5f6f8;
    --card: #ffffff;
    --text: #1a1d21;
    --muted: #6b7280;
    --border: #e5e7eb;
    --up: #0a7d33;
    --down: #c1121f;
    --accent: #2453ff;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #101214;
      --card: #191c1f;
      --text: #edeef0;
      --muted: #9aa1ab;
      --border: #2b2f34;
      --up: #3ddc7a;
      --down: #ff6b6b;
      --accent: #6f92ff;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.45;
  }
  .wrap { max-width: 720px; margin: 0 auto; padding: 20px 16px 60px; }
  header { margin-bottom: 20px; }
  header h1 { font-size: 1.5rem; margin: 0 0 4px; }
  header .sub { color: var(--muted); font-size: 0.9rem; }
  h2.section-title {
    font-size: 1.05rem;
    margin: 28px 0 10px;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--border);
  }
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    margin-bottom: 12px;
  }
  .quote-grid {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 6px 10px;
    font-size: 0.92rem;
  }
  .quote-grid .name { color: var(--text); }
  .quote-grid .price { color: var(--muted); text-align: right; font-variant-numeric: tabular-nums; }
  .change { text-align: right; font-weight: 600; font-variant-numeric: tabular-nums; min-width: 62px; }
  .change.up { color: var(--up); }
  .change.down { color: var(--down); }
  .commentary { font-size: 0.95rem; margin: 0 0 14px; }
  .headline-list { list-style: none; margin: 0; padding: 0; }
  .headline-list li {
    padding: 8px 0;
    border-top: 1px solid var(--border);
  }
  .headline-list li:first-child { border-top: none; }
  .headline-list a {
    color: var(--text);
    text-decoration: none;
    font-size: 0.94rem;
  }
  .headline-list a:hover { color: var(--accent); }
  .headline-list .meta {
    display: block;
    color: var(--muted);
    font-size: 0.78rem;
    margin-top: 2px;
  }
  .bias-tag {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    padding: 1px 6px;
    border-radius: 10px;
    margin-left: 6px;
    letter-spacing: .01em;
  }
  .bias-center { background: rgba(107,114,128,.18); color: var(--muted); }
  .bias-leanleft { background: rgba(45,110,255,.15); color: #3b6fe0; }
  .bias-leanright { background: rgba(220,60,60,.15); color: #c1121f; }
  @media (prefers-color-scheme: dark) {
    .bias-leanleft { color: #8fb2ff; }
    .bias-leanright { color: #ff8f8f; }
  }
  .story-card { margin-bottom: 10px; }
  .story-headline {
    font-weight: 600;
    font-size: 0.95rem;
    margin: 0 0 4px;
  }
  .story-count {
    color: var(--muted);
    font-weight: 500;
    font-size: 0.78rem;
    margin-left: 6px;
  }
  .story-sources {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .story-sources li {
    padding: 4px 0 4px 12px;
    border-left: 2px solid var(--border);
    margin-top: 2px;
  }
  .story-sources a {
    color: var(--text);
    text-decoration: none;
    font-size: 0.85rem;
  }
  .story-sources a:hover { color: var(--accent); }
  .other-headlines-label {
    color: var(--muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: .04em;
    margin: 14px 0 6px;
  }
  footer { margin-top: 30px; color: var(--muted); font-size: 0.8rem; text-align: center; }
  footer .legend { margin-top: 6px; }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1>Daily Digest</h1>
    <div class="sub">{{ generated_date }} · {{ generated_time }}</div>
  </header>

  <h2 class="section-title">Markets</h2>
  <div class="card">
    <p class="commentary">{{ market_commentary }}</p>
  </div>

  {% for region, rows in indices.items() %}
  <div class="card">
    <div class="quote-grid">
      <div class="name" style="color: var(--muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: .04em;">{{ region }}</div>
      <div></div>
      <div></div>
      {% for row in rows %}
      <div class="name">{{ row.name }}</div>
      <div class="price">{{ "%.2f"|format(row.price) }}</div>
      <div class="change {{ 'up' if row.change_pct >= 0 else 'down' }}">{{ "%+.2f"|format(row.change_pct) }}%</div>
      {% endfor %}
    </div>
  </div>
  {% endfor %}

  <div class="card">
    <div class="quote-grid">
      <div class="name" style="color: var(--muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: .04em;">Watchlist</div>
      <div></div>
      <div></div>
      {% for row in watchlist %}
      <div class="name">{{ row.name }}</div>
      <div class="price">{{ "%.2f"|format(row.price) }}</div>
      <div class="change {{ 'up' if row.change_pct >= 0 else 'down' }}">{{ "%+.2f"|format(row.change_pct) }}%</div>
      {% endfor %}
    </div>
  </div>

  {% for section, data in sections.items() %}
  <h2 class="section-title">{{ section }}</h2>
  <div class="card">
    <p class="commentary">{{ data.summary }}</p>

    {% if data.clusters %}
      {% for cluster in data.clusters %}
      <div class="story-card">
        <p class="story-headline">{{ cluster.headline }}<span class="story-count">{{ cluster.sources|length }} sources</span></p>
        <ul class="story-sources">
          {% for item in cluster.sources %}
          <li>
            <a href="{{ item.link }}" target="_blank" rel="noopener">{{ item.source }}</a>
            {% if item.bias %}<span class="bias-tag bias-{{ item.bias|lower|replace(' ', '') }}">{{ item.bias }}</span>{% endif %}
          </li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    {% endif %}

    {% if data.singles %}
    {% if data.clusters %}<div class="other-headlines-label">Also reported</div>{% endif %}
    <ul class="headline-list">
      {% for item in data.singles %}
      <li>
        <a href="{{ item.link }}" target="_blank" rel="noopener">{{ item.title }}</a>
        <span class="meta">{{ item.source }}{% if item.bias %}<span class="bias-tag bias-{{ item.bias|lower|replace(' ', '') }}">{{ item.bias }}</span>{% endif %}</span>
      </li>
      {% endfor %}
    </ul>
    {% endif %}
  </div>
  {% endfor %}

  <footer>
    Generated automatically · sources linked above · not financial advice
    <div class="legend">Bias tags are rough, per-publication editorial-lean labels for context (not a per-article rating).</div>
  </footer>
</div>
</body>
</html>
